# Copy to .env.local for local n8n runs. Do not commit real credentials.

N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_USER_FOLDER=.n8n
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_TEMPLATES_ENABLED=false

# Generate with: openssl rand -hex 32
# Keep the same value once credentials are created, or encrypted credentials
# stored in .n8n will no longer decrypt.
N8N_ENCRYPTION_KEY=

# Optional project/API placeholders used by workflow nodes after import.
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
TIKTOK_ACCESS_TOKEN=
GOOGLE_SHEETS_DOCUMENT_ID=
GOOGLE_SHEETS_SHEET_NAME=
GOOGLE_TASKS_SHEET_NAME=CongViec
GOOGLE_ORDERS_SHEET_NAME=DonHang
GOOGLE_TOKENS_SHEET_NAME=Tokens

# Workflow 15: Product Image Lookup
# Folder ID of Google Drive chứa ảnh sản phẩm (vd "CommentBotImages/").
COMMENT_BOT_DRIVE_FOLDER_ID=
# OAuth2 Bearer token cho Google Drive API (service account hiện tại).
GOOGLE_DRIVE_ACCESS_TOKEN=
